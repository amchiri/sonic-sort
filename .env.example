# AcoustID API key — obtenir gratuitement sur https://acoustid.org/api-key
ACOUSTID_API_KEY=your_key_here

# MusicBrainz user-agent (obligatoire pour l'API)
MB_APP_NAME=SonicSort
MB_APP_VERSION=1.0.0
MB_CONTACT=your@email.com

# Plex (optionnel, pour le scan distant)
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# Limites
MB_RATE_LIMIT_DELAY=1.0
ACOUSTID_CONFIDENCE_THRESHOLD=0.8
